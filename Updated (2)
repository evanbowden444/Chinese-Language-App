朋友,péng you,friend

* {
  box-sizing: border-box;
}

body {
  margin: 0;
  min-height: 100vh;
  font-family: Inter, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  background: linear-gradient(180deg, #f8fafc 0%, #eef2ff 100%);
  color: #0f172a;
}

body.dark-theme {
  background: linear-gradient(180deg, #020617 0%, #111827 100%);
  color: #e2e8f0;
}

button,
input,
textarea {
  font: inherit;
}

button {
  border: 0;
  border-radius: 14px;
  padding: 0.8rem 1.1rem;
  background: #2563eb;
  color: #ffffff;
  cursor: pointer;
  transition: transform 0.15s ease, box-shadow 0.15s ease, opacity 0.15s ease;
}

button:hover {
  transform: translateY(-1px);
  box-shadow: 0 10px 24px rgba(37, 99, 235, 0.18);
}

button:disabled {
  opacity: 0.45;
  cursor: not-allowed;
  transform: none;
  box-shadow: none;
}

.secondary-btn {
  background: #e2e8f0;
  color: #0f172a;
}

body.dark-theme .secondary-btn {
  background: #334155;
  color: #f8fafc;
}

.ghost-btn {
  background: transparent;
  color: #334155;
  border: 1px solid #cbd5e1;
}

body.dark-theme .ghost-btn {
  color: #e2e8f0;
  border-color: #475569;
}

.app-shell {
  max-width: 1200px;
  margin: 0 auto;
  padding: 2rem 1.25rem 3rem;
}

.grid-layout {
  display: grid;
  grid-template-columns: minmax(300px, 360px) 1fr;
  gap: 1.25rem;
}

.panel {
  background: rgba(255, 255, 255, 0.86);
  border: 1px solid rgba(148, 163, 184, 0.2);
  border-radius: 24px;
  box-shadow: 0 20px 50px rgba(15, 23, 42, 0.08);
  backdrop-filter: blur(8px);
}

body.dark-theme .panel {
  background: rgba(15, 23, 42, 0.9);
  border-color: rgba(148, 163, 184, 0.35);
  box-shadow: 0 24px 60px rgba(2, 6, 23, 0.55);
}

.hero {
  display: flex;
  justify-content: space-between;
  gap: 1rem;
  align-items: center;
  margin-bottom: 1.25rem;
  padding: 1.5rem;
}

.eyebrow {
  margin: 0 0 0.45rem;
  text-transform: uppercase;
  letter-spacing: 0.12em;
  font-size: 0.78rem;
  font-weight: 700;
  color: #4f46e5;
}

h1,
h2,
h3,
p {
  margin-top: 0;
}

h1 {
  margin-bottom: 0.7rem;
  font-size: clamp(2rem, 4vw, 3.2rem);
  line-height: 1.05;
}

h2 {
  margin-bottom: 0.6rem;
}

.intro,
.small-copy {
  color: #475569;
}

body.dark-theme .intro,
body.dark-theme .small-copy {
  color: #cbd5e1;
}

.hero-actions,
.button-row {
  display: flex;
  flex-wrap: wrap;
  gap: 0.75rem;
}

.controls-panel,
.study-panel {
  padding: 1.5rem;
}

.upload-label,
.textarea-label {
  display: block;
  margin-bottom: 0.55rem;
  font-weight: 600;
}

.upload-label input {
  display: block;
  width: 100%;
  margin-top: 0.5rem;
  padding: 0.75rem;
  border: 1px dashed #94a3b8;
  border-radius: 16px;
  background: #f8fafc;
}

body.dark-theme .upload-label input {
  background: #0f172a;
  border-color: #475569;
  color: #e2e8f0;
}

textarea {
  width: 100%;
  resize: vertical;
  padding: 1rem;
  border: 1px solid #cbd5e1;
  border-radius: 16px;
  background: #ffffff;
  color: #0f172a;
}

body.dark-theme textarea {
  background: #0b1220;
  border-color: #475569;
  color: #e2e8f0;
}

.divider {
  position: relative;
  margin: 1rem 0;
  text-align: center;
  color: #64748b;
}

body.dark-theme .divider {
  color: #94a3b8;
}

.divider::before {
  content: "";
  position: absolute;
  inset: 50% 0 auto;
  border-top: 1px solid #e2e8f0;
  z-index: 0;
}

body.dark-theme .divider::before {
  border-top-color: #334155;
}

.divider span {
  position: relative;
  z-index: 1;
  padding: 0 0.75rem;
  background: rgba(255, 255, 255, 0.86);
}

body.dark-theme .divider span {
  background: rgba(15, 23, 42, 0.9);
}

.format-panel {
  margin-top: 1rem;
  padding: 1rem;
  border-radius: 18px;
  background: #f8fafc;
}

body.dark-theme .format-panel {
  background: #0b1220;
}

.format-panel pre {
  margin: 0;
  overflow-x: auto;
  font-size: 0.92rem;
  line-height: 1.45;
}

.status-message {
  min-height: 1.5rem;
  margin: 1rem 0 0;
  font-weight: 600;
}

.status-message.success {
  color: #15803d;
}

.status-message.error {
  color: #b91c1c;
}

.study-header,
.deck-table-header,
.toggle-row,
.stats-row {
  display: flex;
  justify-content: space-between;
  gap: 1rem;
  align-items: center;
}

.toggle-row {
  font-size: 0.95rem;
  color: #334155;
}

body.dark-theme .toggle-row {
  color: #cbd5e1;
}

.stats-row {
  margin: 1rem 0 1.2rem;
  flex-wrap: wrap;
}

.stat {
  min-width: 120px;
  padding: 0.9rem 1rem;
  border-radius: 18px;
  background: #f8fafc;
}

body.dark-theme .stat {
  background: #0b1220;
}

.stat-label {
  display: block;
  margin-bottom: 0.35rem;
  font-size: 0.85rem;
  color: #64748b;
}

body.dark-theme .stat-label {
  color: #94a3b8;
}

.flashcard {
  width: 100%;
  min-height: 320px;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  gap: 1rem;
  padding: 2rem;
  border-radius: 28px;
  background: linear-gradient(145deg, #1d4ed8, #4f46e5);
  color: #ffffff;
  text-align: center;
  box-shadow: 0 25px 60px rgba(37, 99, 235, 0.28);
}

.flashcard.is-back {
  background: linear-gradient(145deg, #0f766e, #0f172a);
}

.flashcard.is-empty {
  background: linear-gradient(145deg, #94a3b8, #64748b);
  box-shadow: none;
}

.flashcard-label {
  font-size: clamp(2.3rem, 5vw, 4rem);
  font-weight: 800;
  line-height: 1.1;
}

.flashcard-sub-label {
  max-width: 36rem;
  font-size: clamp(1.1rem, 2vw, 1.4rem);
  color: rgba(255, 255, 255, 0.88);
}

.study-actions {
  margin: 1rem 0 1.5rem;
  justify-content: center;
}

.deck-table-wrap {
  border-top: 1px solid #e2e8f0;
  padding-top: 1.25rem;
}

body.dark-theme .deck-table-wrap {
  border-top-color: #334155;
}

.table-scroll {
  overflow: auto;
}

table {
  width: 100%;
  border-collapse: collapse;
}

th,
td {
  padding: 0.85rem 0.75rem;
  border-bottom: 1px solid #e2e8f0;
  text-align: left;
}

body.dark-theme td,
body.dark-theme th {
  border-bottom-color: #334155;
}

th {
  font-size: 0.85rem;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  color: #64748b;
}

body.dark-theme th {
  color: #94a3b8;
}

.empty-row {
  text-align: center;
  color: #64748b;
}

body.dark-theme .empty-row {
  color: #94a3b8;
}

code {
  background: #e2e8f0;
  padding: 0.12rem 0.35rem;
  border-radius: 6px;
}

body.dark-theme code {
  background: #334155;
}

@media (max-width: 900px) {
  .grid-layout {
    grid-template-columns: 1fr;
  }

  .hero,
  .study-header,
  .deck-table-header {
    flex-direction: column;
    align-items: flex-start;
  }
}
